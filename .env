# ========= SQL Server - Database chính cho BASE service =========
WMSDB_USER=sa
WMSDB_PASSWORD=123456
WMSDB_SERVER=127.0.0.1
WMSDB_DATABASE=TanTrao2026_DB
WMSDB_PORT=1433

# ========= MongoDB (nếu dùng cho logging/pubsub) =========
MONGODB_STRING=mongodb://127.0.0.1:27017

# ========= Goxe API (HTTP — lấy dữ liệu phiếu nhập gỗ xẻ từ Woodsland) =========
# Endpoint do NLG service expose tại WL2020 (xem WL2020/NLG/src/controllers/business/tantrao2026.js)
GOXE_API_URL=https://app.woodsland.com.vn:2002/api/v2/tantrao2026
# Shared API key — phải khớp với TANTRAO2026_API_KEY ở phía WL2020/NLG
GOXE_API_KEY=55291334a2b1b9b7dd858cead63a5bd0de04fd48b80451eb82e222c762d21d49
GOXE_API_TIMEOUT=30000
# 'true' để bỏ qua verify cert HTTPS (chỉ dùng nếu server self-signed)
GOXE_API_INSECURE=false
