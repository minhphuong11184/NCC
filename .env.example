# ========= SQL Server - Database chính cho BASE service =========
WMSDB_USER=sa
WMSDB_PASSWORD=your_password
WMSDB_SERVER=127.0.0.1
WMSDB_DATABASE=TanTrao2026_DB
WMSDB_PORT=1433

# ========= MongoDB (nếu dùng cho logging/pubsub) =========
MONGODB_STRING=mongodb://127.0.0.1:27017

# ========= Goxe API (HTTP — lấy dữ liệu phiếu nhập gỗ xẻ từ Woodsland) =========
# Endpoint do NLG service ở WL2020 expose
GOXE_API_URL=https://app.woodsland.com.vn:2002/api/v2/tantrao2026
# Shared API key (khớp với env TANTRAO2026_API_KEY phía NLG service)
GOXE_API_KEY=
GOXE_API_TIMEOUT=30000
GOXE_API_INSECURE=false
